generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id                        Int                  @id @default(autoincrement())
  name                      String
  phone                     String               @unique
  email                     String?              @unique
  instagramHandle           String?
  instagramFollowConfirmed  Boolean              @default(false)
  uniqueToken               String               @unique
  isActive                  Boolean              @default(true)
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt

  loyaltyStatus             LoyaltyStatus?
  loyaltyTransactions       LoyaltyTransaction[]
  clientViews               ClientView[]
}

model LoyaltyStatus {
  id              Int       @id @default(autoincrement())
  clientId        Int       @unique
  currentChecks   Int       @default(0)
  rewardAvailable Boolean   @default(false)
  cycleNumber     Int       @default(1)
  lastCheckinAt   DateTime?
  lastRedeemedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  client          Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model LoyaltyTransaction {
  id               Int        @id @default(autoincrement())
  clientId         Int
  type             String
  checksDelta      Int        @default(0)
  notes            String?
  createdByUserId  Int?
  createdAt        DateTime   @default(now())

  client           Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdByUser    StaffUser? @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
}

model StaffUser {
  id                  Int                  @id @default(autoincrement())
  name                String
  email               String               @unique
  passwordHash        String
  role                String               @default("staff")
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  loyaltyTransactions LoyaltyTransaction[]
  promotions          Promotion[]
}

model Promotion {
  id               Int        @id @default(autoincrement())
  title            String
  description      String?
  imageUrl         String?
  buttonText       String?
  buttonLink       String?
  startAt          DateTime?
  endAt            DateTime?
  priority         Int        @default(0)
  isActive         Boolean    @default(true)
  createdByUserId  Int?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  createdByUser    StaffUser? @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
}

model ClientView {
  id         Int      @id @default(autoincrement())
  clientId   Int
  source     String?
  viewedAt   DateTime @default(now())

  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}